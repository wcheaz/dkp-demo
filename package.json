{
  "name": "pydantic-ai-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:ui\" \"npm run dev:agent\" --names ui,agent --prefix-colors blue,green --kill-others",
    "dev:debug": "LOG_LEVEL=debug npm run dev",
    "dev:agent": "./scripts/run-agent.sh || scripts/run-agent.bat",
    "dev:ui": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "install:agent": "./scripts/setup-agent.sh || scripts\\setup-agent.bat",
    "postinstall": "npm run install:agent"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.48",
    "@copilotkit/react-core": "^1.54.0",
    "@copilotkit/react-textarea": "^1.54.0",
    "@copilotkit/react-ui": "^1.54.0",
    "@copilotkit/runtime": "^1.54.0",
    "@copilotkitnext/agent": "1.53.0",
    "@tailwindcss/postcss": "^4",
    "@types/papaparse": "^5.5.2",
    "lodash": "^4.17.21",
    "next": "16.1.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "xlsx": "^0.18.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "eslint": "^9",
    "eslint-config-next": "^16.2.1"
  }
}
